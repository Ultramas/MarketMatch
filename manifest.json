{
  "manifest_version": 3,
  "name": "Marketplace Comparison Assistant",
  "version": "0.1.0",
  "description": "Firefox extension for capturing Facebook Marketplace listings and comparing them against eBay Browse API matches through a private backend proxy.",
  "browser_specific_settings": {
    "gecko": {
      "id": "marketplace-comparer@example.local",
      "strict_min_version": "121.0"
    }
  },
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://*.facebook.com/*"
  ],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_title": "Marketplace Comparison Assistant",
    "default_popup": "src/popup.html"
  },
  "options_page": "src/options.html",
  "content_scripts": [
    {
      "matches": [
        "https://*.facebook.com/*"
      ],
      "js": [
        "src/adapters/registry.js",
        "src/adapters/facebook.js",
        "src/content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
